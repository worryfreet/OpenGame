              },
              {
                "type": "string"
              }
            ]
          },
          "choices": {
            "type": "array"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "successCriteria": {
      "type": "string",
      "minLength": 1
    },
