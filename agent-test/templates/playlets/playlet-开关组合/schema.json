{
  "type": "object",
  "additionalProperties": true,
  "required": ["prompt", "switches", "successCriteria"],
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "targetSummary": {
      "type": "string"
    },
    "switches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "targetOn"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "initialOn": { "type": "boolean" },
          "targetOn": { "type": "boolean" },
          "hint": { "type": "string" }
        }
      }
    },
    "successCriteria": {
      "type": "string",
      "minLength": 1
    }
  }
}
