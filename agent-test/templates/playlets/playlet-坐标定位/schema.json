{
  "type": "object",
  "additionalProperties": true,
  "required": [
    "prompt",
    "grid",
    "targets",
    "successCriteria"
  ],
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "targetSummary": {
      "type": "string"
    },
    "grid": {
      "type": "object",
      "required": [
        "columns",
        "rows"
      ],
      "properties": {
        "columns": {
          "type": "number",
          "minimum": 2,
          "maximum": 8
        },
        "rows": {
          "type": "number",
          "minimum": 2,
          "maximum": 8
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "x",
          "y"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "x": {
            "type": "number",
            "minimum": 1
          },
          "y": {
            "type": "number",
            "minimum": 1
          },
          "hint": {
            "type": "string"
          }
        }
      }
    },
    "successCriteria": {
      "type": "string",
      "minLength": 1
    },
    "feedback": {
      "type": "object"
    }
  }
}
