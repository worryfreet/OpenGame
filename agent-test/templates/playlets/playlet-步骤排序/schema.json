{
  "type": "object",
  "additionalProperties": true,
  "required": ["prompt", "steps", "successCriteria"],
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "label", "order"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "number",
            "minimum": 1
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "successCriteria": {
      "type": "string",
      "minLength": 1
    },
    "feedback": {
      "type": "object"
    }
  }
}
