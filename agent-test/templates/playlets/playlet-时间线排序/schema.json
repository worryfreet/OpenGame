{
  "type": "object",
  "additionalProperties": true,
  "required": [
    "prompt",
    "events",
    "successCriteria"
  ],
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "order"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "timeLabel": {
            "type": "string"
          },
          "order": {
            "type": "number"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "successCriteria": {
      "type": "string",
      "minLength": 1
    },
    "feedback": {
      "type": "object"
    }
  }
}
